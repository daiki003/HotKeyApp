<Window x:Class="HotKeyCommandApp.Views.PaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HotKeyCommandApp.ViewModels"
        xmlns:local="clr-namespace:HotKeyCommandApp.Views"
        Title="Command Palette" 
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyUp="Window_KeyUp"
        MinWidth="200" MinHeight="300"
        Width="450" Height="600">

    <Window.Style>
        <Style TargetType="Window">
        </Style>
    </Window.Style>
    
    <Window.InputBindings>
        <KeyBinding Modifiers="Alt" Key="Left" Command="{Binding NavigateBackCommand}" />
        <KeyBinding Modifiers="Alt" Key="Right" Command="{Binding NavigateForwardCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:MenuIndicatorConverter x:Key="MenuIndicatorConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <local:DeleteButtonVisibilityConverter x:Key="DeleteButtonVisibilityConverter" />
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <local:ImageSourceToVisibilityConverter x:Key="ImageSourceToVisibilityConverter" />
        <local:HotkeyTypeToBrushConverter x:Key="HotkeyTypeToBrushConverter" />
        <local:HotkeyToPaddingConverter x:Key="HotkeyToPaddingConverter" />
        
        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FF4444"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HotkeyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsCapturingHotkey}" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#007ACC"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
             <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ListBoxItem_PreviewMouseLeftButtonDown"/>
             <EventSetter Event="MouseMove" Handler="ListBoxItem_MouseMove"/>
             <EventSetter Event="Drop" Handler="ListBoxItem_Drop"/>
        </Style>


    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel x:Name="ViewModel" />
    </Window.DataContext>

    <Border Background="#1E1E1E" 
            CornerRadius="16" 
            BorderBrush="#333333" 
            BorderThickness="1"
            Margin="5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="0" />
        </Border.Effect>
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,10,0,20">
                <Button Command="{Binding GoBackCommand}"
                        Visibility="{Binding CanGoBack, Converter={StaticResource BooleanToVisibilityConverter}}"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Background="Transparent" BorderThickness="0" Foreground="#888888"
                        Margin="10,0,0,0">
                    <TextBlock Text="←" FontSize="24" Margin="0,-5,0,0"/>
                </Button>
                
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Title}" 
                               FontSize="24" FontWeight="Light" Foreground="White"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <Button Command="{Binding OpenSettingsCommand}"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="Transparent" BorderThickness="0" Foreground="#888888"
                        Padding="5" Margin="0,0,10,0">
                    <TextBlock Text="⚙" FontSize="20"/>
                </Button>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Input Mode View (Top) -->
                <StackPanel Grid.Row="0" 
                            Visibility="{Binding IsInputMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                            VerticalAlignment="Top" Margin="15,0,15,10">
                    <TextBlock Text="{Binding InputPrompt}" 
                               Foreground="#888888" FontSize="14" 
                               Margin="5,0,5,5" TextWrapping="Wrap"/>

                    <!-- Value Input (URL/Path) -->
                    <Grid Visibility="{Binding ShowValueInput, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="InputTextBoxBorder" CornerRadius="4,0,0,4" Background="#2D2D2D">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="1.5" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsItemSelected}" Value="False">
                                            <Setter Property="BorderBrush" Value="#007ACC" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBox x:Name="InputTextBox"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" Foreground="White"
                                     BorderThickness="0"
                                     Padding="10" FontSize="16"
                                     CaretBrush="White"
                                     VerticalContentAlignment="Center">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding CommitInputCommand}" />
                                    <KeyBinding Key="Escape" Command="{Binding CancelInputCommand}" />
                                    <KeyBinding Modifiers="Control" Key="P" Command="{Binding BrowseFileCommand}" />
                                    <KeyBinding Modifiers="Alt" Key="Left" Command="{Binding NavigateBackCommand}" />
                                    <KeyBinding Modifiers="Alt" Key="Right" Command="{Binding NavigateForwardCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                        </Border>
                    </Grid>
                </StackPanel>

                <ListBox x:Name="CommandListBox"
                         Grid.Row="1"
                         ItemsSource="{Binding DisplayCommands}"
                         SelectedItem="{Binding SelectedItem}"
                         Visibility="{Binding IsListBoxVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="10,0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="ItemsPanel">
                                <Setter.Value>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="ItemTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid Background="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding IconSource}" 
                                                       Width="20" Height="20" 
                                                       Margin="0,0,10,0" 
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding IconSource, Converter={StaticResource ImageSourceToVisibilityConverter}}"/>
                                                <TextBlock Text="{Binding Name}" 
                                                           FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                                           Foreground="White" 
                                                           VerticalAlignment="Center" 
                                                           TextTrimming="CharacterEllipsis" 
                                                           TextWrapping="Wrap" 
                                                           MaxHeight="{Binding DataContext.ButtonHeight, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.Style>
                    <ListBox.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="3" />
                            <Setter Property="MinWidth" Value="2" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid x:Name="Bg" Background="Transparent" SnapsToDevicePixels="true" Width="{TemplateBinding Width}">
                                            <Track x:Name="PART_Track" Orientation="{TemplateBinding Orientation}"
                                                   IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}"
                                                   Width="{TemplateBinding Width}">
                                                <Track.Thumb>
                                                    <Thumb x:Name="Thumb" Background="#444444" BorderThickness="0"
                                                           MinWidth="2" />
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger SourceName="Thumb" Property="IsMouseOver" Value="true">
                                                <Setter TargetName="Thumb" Property="Background" Value="#666666" />
                                            </Trigger>
                                            <Trigger Property="Orientation" Value="Horizontal">
                                                <Setter Property="Height" Value="2" />
                                                <Setter Property="Width" Value="Auto" />
                                            </Trigger>
                                            <Trigger Property="Orientation" Value="Vertical">
                                                <Setter Property="Width" Value="2" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="Width" Value="{Binding DataContext.ButtonWidth, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                            <Setter Property="Height" Value="{Binding DataContext.ButtonHeight, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder" 
                                                Background="{TemplateBinding Background}" 
                                                CornerRadius="8" 
                                                BorderThickness="1" 
                                                BorderBrush="#444444"
                                                Padding="15,2">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" 
                                                    Command="{Binding DataContext.ExecuteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}" />
                                            </Border.InputBindings>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <ContentPresenter Grid.Column="0" />
                                                
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Border Background="{Binding HotkeyType, Converter={StaticResource HotkeyTypeToBrushConverter}}" 
                                                            CornerRadius="4" Padding="{Binding Hotkey, Converter={StaticResource HotkeyToPaddingConverter}}" 
                                                            MinWidth="20" Margin="0,0,10,0"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding Hotkey, Converter={StaticResource StringToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding Hotkey}" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" TextAlignment="Center" />
                                                    </Border>
                                                    
                                                    <TextBlock Text="›" Foreground="#666666" 
                                                               FontSize="20" VerticalAlignment="Center"
                                                               Visibility="{Binding Converter={StaticResource MenuIndicatorConverter}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#3D3D3D" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#4A4A4A" />
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#007ACC" />
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsTargetedForMove}" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#007ACC" />
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="White" />
                                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="2" />
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Value}" Value="ADD_BUTTON">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Width" Value="{Binding DataContext.ButtonHeight, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                    <Setter Property="Height" Value="{Binding DataContext.ButtonHeight, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                    <Setter Property="Margin" Value="0,5,0,5"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Grid>
                                                    <Border x:Name="ItemBorder" 
                                                            Background="#007ACC" 
                                                            CornerRadius="100" 
                                                            BorderThickness="1" 
                                                            BorderBrush="#007ACC">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick" 
                                                                Command="{Binding DataContext.ExecuteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="{Binding}" />
                                                        </Border.InputBindings>
                                                        <TextBlock Text="+" Foreground="White" FontSize="32" FontWeight="Light" 
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Margin="0,-6,0,0"/>
                                                    </Border>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#108BDE" />
                                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="White" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#005A9E" />
                                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="White" />
                                                        <Setter TargetName="ItemBorder" Property="BorderThickness" Value="2" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="ショートカット設定 [F1]"
                                      Command="{Binding DataContext.StartShortcutAssignmentCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="値を編集 [F2]"
                                      Command="{Binding DataContext.StartEditCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <Separator/>
                            <MenuItem Header="削除 [Del]"
                                      Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.InputBindings>
                        <KeyBinding Key="Enter" 
                                    Command="{Binding DataContext.ExecuteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                        <KeyBinding Key="Right" 
                                    Command="{Binding DataContext.MoveRightCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                        <KeyBinding Key="Left" 
                                    Command="{Binding DataContext.MoveLeftCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                        <KeyBinding Key="Delete" 
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                    </ListBox.InputBindings>
                </ListBox>
            </Grid>
        </Grid>
    </Border>
</Window>

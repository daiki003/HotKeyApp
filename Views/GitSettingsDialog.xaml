<Window x:Class="HotKeyCommandApp.Views.GitSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Git設定" Height="600" Width="700"
        Background="#1E1E1E" Foreground="White"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <!-- Buttons -->
        <Style TargetType="Button" x:Key="ActionButtonStyle">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#444444"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#222222"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="InlineDeleteButtonStyle" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#A80000"/>
            <Setter Property="Padding" Value="3,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        
        <!-- TextBoxes -->
        <Style TargetType="TextBox" x:Key="InputTextBoxStyle">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="TextBox" x:Key="AliasTextBoxStyle" BasedOn="{StaticResource InputTextBoxStyle}">
            <EventSetter Event="PreviewKeyDown" Handler="AliasTextBox_PreviewKeyDown" />
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" Focusable="True" BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Git コマンド設定" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="git_settings.jsonを開く" Style="{StaticResource ActionButtonStyle}" Background="#333333" Padding="8,4" FontSize="12" Click="OpenGitSettings_Click" VerticalAlignment="Center"/>
            </Grid>

            <TabControl x:Name="MainTabControl" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="#2D2D30"/>
                        <Setter Property="Foreground" Value="#888888"/>
                        <Setter Property="Margin" Value="0,0,2,0"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Foreground" Value="#A0C4E2"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.Resources>

                <!-- エイリアス タブ -->
                <TabItem Header="エイリアス">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,10,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="エイリアス名" Foreground="#AAAAAA" />
                            <TextBlock Text="実行コマンド" Foreground="#AAAAAA" Grid.Column="1" Margin="10,0,0,0" />
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="AliasesItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,10,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBox Text="{Binding Alias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AliasTextBoxStyle}" />
                                            <TextBox Text="{Binding TargetCommand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AliasTextBoxStyle}" Grid.Column="1" Margin="10,0,0,0" />
                                            
                                            <Button Content="削除" Grid.Column="2" Margin="10,0,0,0" Style="{StaticResource InlineDeleteButtonStyle}" Click="DeleteAliasInline_Click" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Button x:Name="AddAliasButton" Grid.Row="2" Content="新規追加" Style="{StaticResource ActionButtonStyle}" Background="#007ACC" HorizontalAlignment="Left" Margin="0,10,0,0" Click="AddAlias_Click" />
                    </Grid>
                </TabItem>

                <!-- 関数 タブ -->
                <TabItem Header="関数">
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="250"/>
                        </Grid.ColumnDefinitions>
                        
                        <ListBox x:Name="FunctionsListBox" Background="#252526" Foreground="White" BorderBrush="#333333" SelectionChanged="FunctionsListBox_SelectionChanged" DisplayMemberPath="Name" />
                        
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="関数名" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                            <TextBox x:Name="FunctionNameTextBox" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,10" TextChanged="FunctionTextBox_TextChanged"/>
                            
                            <TextBlock Text="説明" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                            <TextBox x:Name="FunctionDescTextBox" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,10" TextChanged="FunctionTextBox_TextChanged"/>
                            
                            <TextBlock Text="コマンド群 (1行1コマンド)" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                            <TextBox x:Name="FunctionCommandsTextBox" Style="{StaticResource InputTextBoxStyle}" Height="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15" TextChanged="FunctionTextBox_TextChanged"/>
                            
                            <Button Content="新規追加" Style="{StaticResource ActionButtonStyle}" Background="#007ACC" Click="AddFunction_Click" Margin="0,0,0,10"/>
                            <Button Content="削除" Style="{StaticResource ActionButtonStyle}" Background="#A80000" Click="DeleteFunction_Click"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="キャンセル" Style="{StaticResource ActionButtonStyle}" Click="Close_Click" Margin="0,0,10,0"/>
                <Button x:Name="SaveAndCloseButton" Content="保存して閉じる" Style="{StaticResource ActionButtonStyle}" Background="#007ACC" Click="SaveAndClose_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

<Window x:Class="HotKeyCommandApp.Views.GitSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Git設定" Height="400" Width="450"
        Background="#1E1E1E" Foreground="White"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Window.Resources>
        <!-- Buttons -->
        <Style TargetType="Button" x:Key="ActionButtonStyle">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#444444"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#222222"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Git コマンド設定" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
            <TextBlock Grid.Row="1" Text="Gitのエイリアス（短縮コマンド）や、複数のコマンドを自動で連続実行する関数（GitFunctions）を設定できます。" 
                       Foreground="#AAAAAA" TextWrapping="Wrap" Margin="0,0,0,20"/>

            <Border Grid.Row="2" Background="#121212" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="現在の設定は専用ファイルに保存されています。" Foreground="#D4D4D4" Margin="0,0,0,10"/>
                    <TextBlock Text="以下のボタンから settings.json と同じ要領で編集してください。" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,15"/>
                    <Button Content="git_settings.json を開く" Style="{StaticResource ActionButtonStyle}" Background="#007ACC" Click="OpenGitSettings_Click" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="閉じる" Style="{StaticResource ActionButtonStyle}" Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

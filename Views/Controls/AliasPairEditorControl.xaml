<UserControl x:Class="HotKeyCommandApp.Views.Controls.AliasPairEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HotKeyCommandApp.Views.Controls"
             xmlns:views="clr-namespace:HotKeyCommandApp.Views"
             x:Name="Root">
    <UserControl.Resources>
        <local:PairItemVisibilityConverter x:Key="PairItemVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <views:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#444444"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#222222"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InlineDeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#A80000"/>
            <Setter Property="Padding" Value="3,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="RowButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PairEntryTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <EventSetter Event="PreviewKeyDown" Handler="EntryTextBox_PreviewKeyDown"/>
            <EventSetter Event="GotFocus" Handler="EntryTextBox_GotFocus"/>
            <EventSetter Event="LostKeyboardFocus" Handler="EntryTextBox_LostKeyboardFocus"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="CurrentFolderTextBlock"
                       Foreground="#D4D4D4"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <Grid Grid.Row="1" Margin="10,0,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="{Binding ElementName=Root, Path=DisplayValueOffset}"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="BackHintTextBlock"
                       Grid.Column="0"
                       Text="←"
                       Foreground="#AAAAAA"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding ElementName=Root, Path=FirstHeader}"
                       Foreground="#AAAAAA"
                       HorizontalAlignment="Left"/>
            <TextBlock Grid.Column="2"
                       Text="{Binding ElementName=Root, Path=SecondHeader}"
                       Foreground="#AAAAAA"
                       HorizontalAlignment="Left"/>
        </Grid>

        <ScrollViewer x:Name="ItemsScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ItemsControl x:Name="PairItemsControl"
                              ItemsSource="{Binding ElementName=Root, Path=VisibleItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,10,5" AllowDrop="True" DragOver="Row_DragOver" Drop="Row_Drop">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="{Binding ElementName=Root, Path=DisplayValueOffset}"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="RowButton"
                                    Grid.ColumnSpan="4"
                                    Style="{StaticResource RowButtonStyle}"
                                    Click="RowButton_Click"
                                    PreviewKeyDown="RowButton_PreviewKeyDown">
                                <Button.Visibility>
                                    <MultiBinding Converter="{StaticResource PairItemVisibilityConverter}" ConverterParameter="Display">
                                        <Binding/>
                                        <Binding ElementName="Root" Path="CurrentEditingItem"/>
                                        <Binding Path="IsFolder"/>
                                    </MultiBinding>
                                </Button.Visibility>
                                <Grid Margin="10,0,10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="{Binding ElementName=Root, Path=DisplayValueOffset}"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="☰"
                                               Foreground="#666666"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Cursor="SizeAll"
                                               PreviewMouseLeftButtonDown="DragHandle_PreviewMouseLeftButtonDown"
                                               PreviewMouseMove="DragHandle_PreviewMouseMove"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding FirstValue}"
                                               Foreground="White"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Margin="0,8,0,8"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SecondValue}"
                                               Foreground="#D4D4D4"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Margin="0,8,0,8"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding IsFolder, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                    <TextBlock Grid.Column="2"
                                               Text="▶"
                                               Foreground="#AAAAAA"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0"
                                               Visibility="{Binding IsFolder, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </Button>

                            <Grid Grid.ColumnSpan="4">
                                <Grid.Visibility>
                                    <MultiBinding Converter="{StaticResource PairItemVisibilityConverter}" ConverterParameter="RecordEdit">
                                        <Binding/>
                                        <Binding ElementName="Root" Path="CurrentEditingItem"/>
                                        <Binding Path="IsFolder"/>
                                    </MultiBinding>
                                </Grid.Visibility>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="{Binding ElementName=Root, Path=DisplayValueOffset}"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="☰"
                                           Foreground="#666666"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Cursor="SizeAll"
                                           PreviewMouseLeftButtonDown="DragHandle_PreviewMouseLeftButtonDown"
                                           PreviewMouseMove="DragHandle_PreviewMouseMove"/>

                                <TextBox Grid.Column="1"
                                         Text="{Binding FirstValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PairEntryTextBoxStyle}"/>
                                <TextBox Grid.Column="2"
                                         Text="{Binding SecondValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PairEntryTextBoxStyle}"
                                         Margin="10,0,0,0"/>

                                <Button Content="削除"
                                        Grid.Column="3"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource InlineDeleteButtonStyle}"
                                        Click="DeleteInline_Click"/>
                            </Grid>

                            <Grid Grid.ColumnSpan="4">
                                <Grid.Visibility>
                                    <MultiBinding Converter="{StaticResource PairItemVisibilityConverter}" ConverterParameter="FolderEdit">
                                        <Binding/>
                                        <Binding ElementName="Root" Path="CurrentEditingItem"/>
                                        <Binding Path="IsFolder"/>
                                    </MultiBinding>
                                </Grid.Visibility>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="{Binding ElementName=Root, Path=DisplayValueOffset}"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="☰"
                                           Foreground="#666666"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Cursor="SizeAll"
                                           PreviewMouseLeftButtonDown="DragHandle_PreviewMouseLeftButtonDown"
                                           PreviewMouseMove="DragHandle_PreviewMouseMove"/>

                                <TextBox Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding FirstValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PairEntryTextBoxStyle}"/>

                                <Button Content="削除"
                                        Grid.Column="3"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource InlineDeleteButtonStyle}"
                                        Click="DeleteInline_Click"/>
                            </Grid>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <Button x:Name="AddItemButton"
                    Content="{Binding ElementName=Root, Path=AddButtonText}"
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#007ACC"
                    HorizontalAlignment="Left"
                    PreviewKeyDown="AddItemButton_PreviewKeyDown"
                    Click="AddItemButton_Click"/>
            <Button x:Name="AddFolderButton"
                    Content="{Binding ElementName=Root, Path=AddFolderButtonText}"
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#4C6A92"
                    HorizontalAlignment="Left"
                    Margin="10,0,0,0"
                    PreviewKeyDown="AddFolderButton_PreviewKeyDown"
                    Click="AddFolderButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>

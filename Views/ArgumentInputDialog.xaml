<Window x:Class="HotKeyCommandApp.Views.ArgumentInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input Argument" 
        Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="3" />
                    <Setter Property="MinWidth" Value="2" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid x:Name="Bg" Background="Transparent" SnapsToDevicePixels="true" Width="{TemplateBinding Width}">
                                    <Track x:Name="PART_Track" Orientation="{TemplateBinding Orientation}"
                                           IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                        <Track.Thumb>
                                            <Thumb x:Name="Thumb" Background="#444444" BorderThickness="0" MinWidth="2" />
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger SourceName="Thumb" Property="IsMouseOver" Value="true">
                                        <Setter TargetName="Thumb" Property="Background" Value="#666666" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="3" />
                    <Setter Property="MinHeight" Value="2" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid x:Name="Bg" Background="Transparent" SnapsToDevicePixels="true" Height="{TemplateBinding Height}">
                                    <Track x:Name="PART_Track" Orientation="{TemplateBinding Orientation}"
                                           IsDirectionReversed="false" IsEnabled="{TemplateBinding IsEnabled}">
                                        <Track.Thumb>
                                            <Thumb x:Name="Thumb" Background="#444444" BorderThickness="0" MinHeight="2" />
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger SourceName="Thumb" Property="IsMouseOver" Value="true">
                                        <Setter TargetName="Thumb" Property="Background" Value="#666666" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#2D2D2D" 
            CornerRadius="12" 
            BorderBrush="#007ACC" 
            BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.5" ShadowDepth="0" />
        </Border.Effect>
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock x:Name="PromptTextBlock" Grid.Row="0"
                       Text="引数を入力してください:" 
                       Foreground="#AAAAAA" FontSize="13" 
                       Margin="5,0,0,8" TextWrapping="Wrap"/>
            
            <Grid Grid.Row="1">
                <Border CornerRadius="6" Background="#3D3D3D" BorderThickness="1.5" Padding="2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="#555555" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedIndex, ElementName=HistoryListBox}" Value="-1">
                                    <Setter Property="BorderBrush" Value="#007ACC" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <ScrollViewer x:Name="InputScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="InputsStackPanel" Orientation="Horizontal">
                            <!-- TextBoxes will be added dynamically in code-behind -->
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid x:Name="HistoryContainer" Grid.Row="2" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="最近の入力" Foreground="#666666" FontSize="11" Margin="5,0,0,8" Grid.Row="0"/>
                <ListBox x:Name="HistoryListBox" Grid.Row="1"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#CCCCCC"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         HorizontalContentAlignment="Stretch"
                         PreviewMouseLeftButtonDown="HistoryListBox_PreviewMouseLeftButtonDown">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Background" Value="#2D2D2D"/>
                            <Setter Property="BorderBrush" Value="#444444" />
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Padding" Value="0,5"/>
                            <Setter Property="Margin" Value="0,0,0,6"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder" 
                                                Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#3D3D3D"/>
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#666666"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#3E3E42"/>
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#007ACC"/>
                                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="10,0,0,0" Foreground="White" FontSize="14" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
            
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,5,0">
                <TextBlock Text="↑↓: 履歴選択" Foreground="#555555" FontSize="10" Margin="0,0,15,0" VerticalAlignment="Center"/>
                <TextBlock Text="Enter: 決定 / Esc: 閉じる" 
                           Foreground="#555555" FontSize="10" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

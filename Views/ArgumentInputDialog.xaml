<Window x:Class="HotKeyCommandApp.Views.ArgumentInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input Argument" 
        SizeToContent="Height" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border Background="#2D2D2D" 
            CornerRadius="12" 
            BorderBrush="#007ACC" 
            BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.5" ShadowDepth="0" />
        </Border.Effect>
        <StackPanel Margin="15">
            <TextBlock x:Name="PromptTextBlock" 
                       Text="引数を入力してください:" 
                       Foreground="#AAAAAA" FontSize="13" 
                       Margin="5,0,0,8" TextWrapping="Wrap"/>
            
            <Border CornerRadius="6" Background="#3D3D3D" BorderThickness="1.5" Padding="2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="#555555" />
                        <Style.Triggers>
                            <!-- 履歴リスト（HistoryListBox）で何も選択されていない時（-1）に、枠を青くする -->
                            <DataTrigger Binding="{Binding SelectedIndex, ElementName=HistoryListBox}" Value="-1">
                                <Setter Property="BorderBrush" Value="#007ACC" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBox x:Name="InputTextBox"
                         Background="Transparent" Foreground="White"
                         BorderThickness="0"
                         Padding="10,8" FontSize="15"
                         CaretBrush="White"
                         VerticalContentAlignment="Center"
                         AcceptsReturn="False"/>
            </Border>

            <Grid x:Name="HistoryContainer" Margin="0,10,0,0" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="最近の入力" Foreground="#666666" FontSize="11" Margin="5,0,0,8"/>
                    <ListBox x:Name="HistoryListBox"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#CCCCCC" MaxHeight="300"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             HorizontalContentAlignment="Stretch"
                             PreviewMouseLeftButtonDown="HistoryListBox_PreviewMouseLeftButtonDown">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Background" Value="#2D2D2D"/>
                                <Setter Property="BorderBrush" Value="#444444" />
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding" Value="0,5"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder" 
                                                    Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#3D3D3D"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#666666"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#3E3E42"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#007ACC"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1.5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Margin="10,0,0,0" Foreground="White" FontSize="14" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,5,0">
                <TextBlock Text="↑↓: 履歴選択" Foreground="#555555" FontSize="10" Margin="0,0,15,0" VerticalAlignment="Center"/>
                <TextBlock Text="Enter: 決定 / Esc: 閉じる" 
                           Foreground="#555555" FontSize="10" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>

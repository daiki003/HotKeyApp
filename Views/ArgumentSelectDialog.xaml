<Window x:Class="HotKeyCommandApp.Views.ArgumentSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Argument" 
        Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Border Background="#2D2D2D" 
            CornerRadius="12" 
            BorderBrush="#007ACC" 
            BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.5" ShadowDepth="0" />
        </Border.Effect>
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock x:Name="PromptTextBlock" Grid.Row="0"
                       Text="選択してください:" 
                       Foreground="#AAAAAA" FontSize="13" 
                       Margin="5,0,0,8" TextWrapping="Wrap"/>
            
            <Border Grid.Row="1" Background="#3D3D3D" CornerRadius="6" BorderThickness="1" BorderBrush="#555555" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔍" Foreground="#AAAAAA" FontSize="14" VerticalAlignment="Center" Margin="8,0,4,0" />
                    <TextBox Grid.Column="1" x:Name="SearchTextBox" 
                             Background="Transparent" Foreground="White" BorderThickness="0"
                             FontSize="14" Padding="0,5,5,5" VerticalContentAlignment="Center"
                             TextChanged="SearchTextBox_TextChanged" />
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <ListBox x:Name="OptionsListBox"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#CCCCCC"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         HorizontalContentAlignment="Stretch"
                         PreviewMouseLeftButtonDown="OptionsListBox_PreviewMouseLeftButtonDown">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Background" Value="#2D2D2D"/>
                            <Setter Property="BorderBrush" Value="#444444" />
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Padding" Value="0,5"/>
                            <Setter Property="Margin" Value="0,0,0,6"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder" 
                                                Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#3D3D3D"/>
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#666666"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#3E3E42"/>
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#007ACC"/>
                                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="10,0,0,0" Foreground="White" FontSize="14" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
            
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,5,0">
                <TextBlock Text="↑↓: 選択" Foreground="#555555" FontSize="10" Margin="0,0,15,0" VerticalAlignment="Center"/>
                <TextBlock Text="Enter: 決定 / Esc: 閉じる" 
                           Foreground="#555555" FontSize="10" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

<Window x:Class="HotKeyCommandApp.Views.WindowSwitcherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HotKeyCommandApp.Views"
        Title="Window Switcher" 
        WindowStartupLocation="Manual"
        Left="-20000"
        Top="-20000"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Opacity="1"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        MaxWidth="1200"
        KeyUp="Window_KeyUp"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <local:ImageSourceToVisibilityConverter x:Key="ImageSourceToVisibilityConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        
        <!-- Window Switcher Thumbnail Template -->
        <DataTemplate x:Key="WindowThumbnailTemplate">
            <Grid Width="200" Height="170" Margin="5">
                <Border x:Name="ThumbBorder" Background="#2D2D2D" CornerRadius="0" BorderBrush="#444444" BorderThickness="1.5" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Header Area: Icon + Name -->
                        <Border Grid.Row="0" Background="#CC1E1E1E" Padding="10,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0" Source="{Binding IconSource}" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"
                                       Visibility="{Binding IconSource, Converter={StaticResource ImageSourceToVisibilityConverter}}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="White" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>

                        <!-- Content Area: Thumbnail View -->
                        <Border Grid.Row="1" Background="Transparent" Margin="2">
                            <local:WindowThumbnailView SourceWindowHandle="{Binding WindowHandle}" 
                                                       IsThumbnailEnabled="{Binding IsThumbnailEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       Margin="0" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="#007ACC" />
                    <Setter TargetName="ThumbBorder" Property="BorderThickness" Value="2.5" />
                    <Setter TargetName="ThumbBorder" Property="Background" Value="#3D3D3D" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Border Background="#CC121212" 
            CornerRadius="20" 
            BorderBrush="#444444" 
            BorderThickness="1.5"
            Margin="20">
        <Border.CacheMode>
            <BitmapCache RenderAtScale="1" />
        </Border.CacheMode>
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Opacity="0.7" ShadowDepth="0" />
        </Border.Effect>
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding ActiveWindowSwitcherCommand.Value}" 
                       Foreground="#00A2FF" 
                       FontSize="18" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center" 
                       Margin="0,10,0,15" />

            <ListBox x:Name="SwitcherListBox"
                     Grid.Row="1"
                     ItemsSource="{Binding WindowSwitcherItems}"
                     SelectedItem="{Binding SelectedWindowItem}"
                     ItemTemplate="{StaticResource WindowThumbnailTemplate}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="2" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="IsSelected" Value="True" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>
    </Border>
</Window>

<Window x:Class="HotKeyCommandApp.Views.ButtonCreationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HotKeyCommandApp.ViewModels"
        xmlns:local="clr-namespace:HotKeyCommandApp.Views"
        Title="{Binding Title.Value}" 
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        Loaded="Window_Loaded"
        SizeToContent="Manual">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:MenuIndicatorConverter x:Key="MenuIndicatorConverter" />
    </Window.Resources>

    <Border Background="#1E1E1E" 
            CornerRadius="16" 
            BorderBrush="#007ACC" 
            BorderThickness="2"
            Margin="5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="0" />
        </Border.Effect>
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="{Binding Title.Value}" 
                           FontSize="20" FontWeight="Light" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- Page Indicators (Dots) with Guides -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15"
                        Visibility="{Binding ShowStepIndicators.Value, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="PageUp" Foreground="#666666" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <ItemsControl ItemsSource="{Binding PageIndicatorSteps}" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Ellipse Width="8" Height="8" Margin="5,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#444444" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCurrent.Value}" Value="True">
                                                <Setter Property="Fill" Value="#007ACC" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="PageDown" Foreground="#666666" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Input View (Top) -->
                <StackPanel Grid.Row="0" VerticalAlignment="Top" Margin="0,0,0,10">
                    <TextBlock Text="{Binding InputPrompt.Value}" 
                               Foreground="#888888" FontSize="14" 
                               Margin="0,0,0,5" TextWrapping="Wrap"/>

                    <!-- Value Input (URL/Path) -->
                    <Grid Visibility="{Binding IsTextInputVisible.Value, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="InputTextBoxBorder" CornerRadius="4,0,0,4" Background="#2D2D2D">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="1.5" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsItemSelected.Value}" Value="False">
                                            <Setter Property="BorderBrush" Value="#007ACC" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBox x:Name="InputTextBox"
                                     Text="{Binding InputText.Value, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" Foreground="White"
                                     BorderThickness="0"
                                     Padding="10" FontSize="16"
                                     CaretBrush="White"
                                     GotFocus="TextBox_GotFocus"
                                     VerticalContentAlignment="Center">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding CommitInputCommand}" />
                                    <KeyBinding Key="Escape" Command="{Binding CancelInputCommand}" />
                                    <KeyBinding Modifiers="Control" Key="P" Command="{Binding BrowseFileCommand}" />
                                    <KeyBinding Key="PageUp" Command="{Binding MoveToPreviousStepCommand}" />
                                    <KeyBinding Key="PageDown" Command="{Binding MoveToNextStepCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                        </Border>
                        <Button Grid.Column="1" Command="{Binding BrowseFileCommand}"
                                Visibility="{Binding ShowMainBrowseButton.Value, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Content="📂" Background="#3D3D3D" Foreground="White" 
                                Padding="10,0" FontSize="16" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0,1,1,1" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="0,4,4,0">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsItemSelected}" Value="False">
                                            <Setter Property="BorderBrush" Value="#007ACC" />
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4A4A4A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                        <!-- App Path Input has been replaced purely by ListBox selection -->

                    <!-- Options (Argument / File Search) -->
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left"
                                Margin="5,10,0,0">
                        <CheckBox Content="引数を要求 (F1)" 
                                  IsChecked="{Binding CurrentStepObject.Value.IsRequiresArgumentChecked.Value}"
                                  Foreground="#CCCCCC" VerticalContentAlignment="Center"
                                  Visibility="{Binding ShowArgumentOption.Value, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Margin="0,0,0,8"/>
                        <CheckBox Content="ファイル検索モード (F2)" 
                                  IsChecked="{Binding CurrentStepObject.Value.IsFileSearchChecked.Value}"
                                  Foreground="#CCCCCC" VerticalContentAlignment="Center"
                                  Visibility="{Binding ShowFileSearchOption.Value, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Margin="0,0,0,8"/>
                        <CheckBox Content="コマンド実行モード (F3)" 
                                  IsChecked="{Binding CurrentStepObject.Value.IsBatchModeChecked.Value}"
                                  Foreground="#CCCCCC" VerticalContentAlignment="Center"
                                  Visibility="{Binding ShowBatchModeOption.Value, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Margin="0,0,0,8"/>
                        <CheckBox Content="ウィンドウフォーカス制御 (F4)" 
                                  IsChecked="{Binding CurrentStepObject.Value.UseWindowFocusLogicChecked.Value}"
                                  Foreground="#CCCCCC" VerticalContentAlignment="Center"
                                  Visibility="{Binding ShowFocusLogicOption.Value, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Margin="0,0,0,8"/>
                    </StackPanel>
                </StackPanel>

                <ProgressBar Grid.Row="1" 
                             Height="2" 
                             IsIndeterminate="True" 
                             VerticalAlignment="Top"
                             Foreground="#007ACC"
                             Background="Transparent"
                             BorderThickness="0"
                             Panel.ZIndex="1"
                             Visibility="{Binding IsSearching.Value, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <ListBox x:Name="CommandListBox"
                         Grid.Row="1"
                         ItemsSource="{Binding DisplayCommands.Value}"
                         SelectedItem="{Binding SelectedItem.Value}"
                         Visibility="{Binding IsListBoxVisible.Value, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Background="Transparent"
                         BorderThickness="0"
                         FocusVisualStyle="{x:Null}"
                         Padding="0"
                         ScrollViewer.VerticalScrollBarVisibility="Visible"
                         ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                         HorizontalContentAlignment="Stretch">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        <Setter Property="Width" Value="{Binding DataContext.ButtonWidth, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                        <Setter Property="Height" Value="{Binding DataContext.ButtonHeight, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                        <Setter Property="Margin" Value="0,0,0,8" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder" 
                                            Background="{TemplateBinding Background}" 
                                            CornerRadius="8" 
                                            BorderThickness="1" 
                                            BorderBrush="#444444"
                                            Padding="15,2">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" 
                                                Command="{Binding DataContext.ExecuteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <ContentPresenter Grid.Column="0" />
                                                <TextBlock Grid.Column="1" Text="›" Foreground="#666666" 
                                                           FontSize="20" VerticalAlignment="Center"
                                                           Visibility="{Binding Converter={StaticResource MenuIndicatorConverter}}"/>
                                            </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#3D3D3D" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#4A4A4A" />
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#007ACC" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Background="Transparent">
                            <TextBlock Text="{Binding Name}" Margin="5,0,5,0" FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=ListBox}}" Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="{Binding DataContext.ButtonHeight, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.InputBindings>
                    <KeyBinding Key="Enter" 
                                Command="{Binding DataContext.ExecuteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                    <KeyBinding Key="Down" Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                    <KeyBinding Key="Up" Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                    <KeyBinding Key="PageUp" Command="{Binding DataContext.MoveToPreviousStepCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                    <KeyBinding Key="PageDown" Command="{Binding DataContext.MoveToNextStepCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                </ListBox.InputBindings>
            </ListBox>
            </Grid>
        </Grid>
    </Border>
</Window>

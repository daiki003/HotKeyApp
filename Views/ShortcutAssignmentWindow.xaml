<Window x:Class="HotKeyCommandApp.Views.ShortcutAssignmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HotKeyCommandApp.Views"
        Title="Assign Shortcut" 
        SizeToContent="WidthAndHeight" Width="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <local:HotkeyTypeToBrushConverter x:Key="HotkeyTypeToBrushConverter" />
    </Window.Resources>
    
    <Border Background="#2D2D2D" 
            CornerRadius="12" 
            BorderBrush="#007ACC" 
            BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.5" ShadowDepth="0" />
        </Border.Effect>
        <StackPanel Margin="20">
            <TextBlock Text="ショートカットの設定" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
            
            <TextBlock x:Name="PromptTextBlock" 
                       Text="アイテムに割り当てるキーを押してください" 
                       Foreground="#AAAAAA" FontSize="13" 
                       HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                       Margin="0,0,0,15"/>

            <ListBox x:Name="TypeListBox" Background="Transparent" BorderThickness="0" Margin="0,0,0,20">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Border" 
                                            Padding="10,8" 
                                            Background="Transparent" 
                                            CornerRadius="6"
                                            Margin="0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="12" Height="12" CornerRadius="6" Margin="0,0,10,0"
                                                        Background="{Binding Type, Converter={StaticResource HotkeyTypeToBrushConverter}}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="White" FontSize="14"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Description}" Foreground="#888888" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#37373D"/>
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#007ACC"/>
                                            <Setter TargetName="Border" Property="BorderThickness" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.Resources>
                <!-- Items will be populated in Code-behind -->
            </ListBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="キャンセル (Esc)" Click="CancelButton_Click" 
                        Background="#444444" Foreground="White" Padding="20,8" 
                        BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                <Button Content="削除 (Delete)" Click="DeleteButton_Click" 
                        Background="#555555" Foreground="White" Padding="20,8" 
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>

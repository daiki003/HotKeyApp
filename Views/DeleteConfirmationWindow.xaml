<Window x:Class="HotKeyCommandApp.Views.DeleteConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delete Confirmation" 
        SizeToContent="WidthAndHeight" Width="350"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        PreviewKeyDown="Window_PreviewKeyDown">
    
    <Border Background="#2D2D2D" 
            CornerRadius="12" 
            BorderBrush="#FF4444" 
            BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.5" ShadowDepth="0" />
        </Border.Effect>
        <StackPanel Margin="20">
            <TextBlock Text="削除の確認" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
            
            <TextBlock x:Name="MessageTextBlock" 
                       Text="このアイテムを削除しますか？" 
                       Foreground="White" FontSize="14" 
                       HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                       Margin="0,0,0,25"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border x:Name="DeleteButtonBorder" Margin="0,0,10,0" CornerRadius="4">
                    <Button x:Name="DeleteButton" Content="削除" Click="DeleteButton_Click" 
                            Background="#FF4444" Foreground="White" Padding="25,10" 
                            BorderThickness="0" Cursor="Hand"/>
                </Border>
                <Border x:Name="CancelButtonBorder" CornerRadius="4">
                    <Button x:Name="CancelButton" Content="キャンセル" Click="CancelButton_Click" 
                            Background="#444444" Foreground="White" Padding="25,10" 
                            BorderThickness="0" Cursor="Hand"/>
                </Border>
            </StackPanel>
            
            <TextBlock Text="Enterで実行 / Escで戻る" 
                       Foreground="#666666" FontSize="11" 
                       HorizontalAlignment="Center" Margin="0,15,0,0" />
        </StackPanel>
    </Border>
</Window>
